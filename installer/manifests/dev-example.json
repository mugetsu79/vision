{
  "version": "dev-local",
  "release_channel": "dev",
  "images": {
    "backend": {
      "reference": "vezor/backend:portable-demo"
    },
    "frontend": {
      "reference": "vezor/frontend:portable-demo"
    },
    "postgres": {
      "reference": "timescale/timescaledb:latest-pg16"
    },
    "redis": {
      "reference": "redis:7"
    },
    "nats": {
      "reference": "nats:2"
    },
    "minio": {
      "reference": "minio/minio:latest"
    },
    "mediamtx": {
      "reference": "bluenviron/mediamtx:latest"
    },
    "keycloak": {
      "reference": "quay.io/keycloak/keycloak:latest"
    },
    "supervisor": {
      "reference": "vezor/backend:portable-demo"
    },
    "edge-worker": {
      "reference": "vezor/edge-worker:portable-demo"
    }
  },
  "package_targets": [
    {
      "name": "linux-master",
      "os": "linux",
      "role": "master",
      "architectures": ["amd64"],
      "ports": [80, 443, 8000, 8080, 9000]
    },
    {
      "name": "macos-master",
      "os": "darwin",
      "role": "master",
      "architectures": ["arm64", "amd64"],
      "ports": [3000, 8000, 8080, 9000]
    },
    {
      "name": "jetson-edge",
      "os": "linux",
      "role": "edge",
      "architectures": ["arm64"],
      "ports": [8554, 9108]
    }
  ],
  "minimum_versions": {
    "python": "3.12",
    "container_engine": "24.0",
    "compose": "2.24",
    "jetpack": "6.0"
  },
  "jetson_ort_wheels": [
    {
      "jetpack": "6.2",
      "l4t": "36.5",
      "python": "cp310",
      "arch": "aarch64",
