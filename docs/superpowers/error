cd "$HOME/vision"
git pull --rebase origin main
docker compose -f infra/docker-compose.dev.yml up -d --force-recreate minio backend
docker compose -f infra/docker-compose.dev.yml logs --tail 20 minio
curl -I http://127.0.0.1:9001
```

What you should see:
