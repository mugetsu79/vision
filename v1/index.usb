<!DOCTYPE html>
<html>
<head>
    <title>Traffic Monitor</title>
    <script src="https://cdn.socket.io/4.0.0/socket.io.min.js"></script>
</head>
<body>
    <h1>Traffic Monitor</h1>
    <div>
        <img id="video-feed" width="320" height="180" />
    </div>
    <div>
        <p>Car Count: <span id="car-count">0</span></p>
        <p>Total Car Count: <span id="total-car-count">0</span></p>
    </div>
    <div>
        <form id="time-range-form">
            <label for="start_time">Start Time:</label>
            <input type="datetime-local" id="start_time" name="start_time">
            <label for="end_time">End Time:</label>
            <input type="datetime-local" id="end_time" name="end_time">
            <button type="button" onclick="updateGraph()">Update Graph</button>
        </form>
        <div id="graph-container"></div>
    </div>
    <script>
        var socket = io();

        socket.on('frame', function(data) {
            var img = document.getElementById('video-feed');
            img.src = 'data:image/jpeg;base64,' + btoa(String.fromCharCode.apply(null, new Uint8Array(data.frame)));
            document.getElementById('car-count').innerText = data.car_count;
            document.getElementById('total-car-count').innerText = data.total_car_count;
        });

        async function updateGraph() {
            var start_time = document.getElementById('start_time').value;
            var end_time = document.getElementById('end_time').value;

            try {
                let response = await fetch(`/graph?start_time=${start_time}&end_time=${end_time}`);
                if (response.ok) {
                    let graphHtml = await response.text();
                    document.getElementById('graph-container').innerHTML = graphHtml;
                } else {
                    console.error('Failed to fetch graph data:', response.statusText);
                }
            } catch (error) {
                console.error('Error fetching graph data:', error);
            }
        }
    </script>
</body>
</html>

